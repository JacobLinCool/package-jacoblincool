        "eslint": "8.20.0",
        "eslint-config-prettier": "8.5.0",
        "jest": "27.5.1",
        "prettier": "2.7.1",
        "ts-jest": "27.1.5",
        "tsup": "5.12.9",
        "typedoc": "0.22.18",
        "typescript": "4.7.4"
    }
}
